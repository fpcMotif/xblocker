# Optional Convex cloud backup. Copy to `.env` and fill in to enable.
# See convex/README.md for the full setup (Convex deployment + Google OAuth client).
#
# WXT/Vite exposes VITE_-prefixed vars to the extension via import.meta.env.

# Your Convex deployment URL, e.g. https://your-app-123.convex.cloud
VITE_CONVEX_URL=

# The Google OAuth client id. Must match GOOGLE_OAUTH_CLIENT_ID set in the Convex
# dashboard (Settings -> Environment Variables).
VITE_GOOGLE_OAUTH_CLIENT_ID=

# One-click manual block strategy (ADR-0001). Rebuild after change.
#   auto-confirm — bypass X's native Block/Mute confirmation sheet (default)
#   inline       — Cursor Console per-reply buttons (direct API)
#   off          — disabled
# VITE_QUICK_BLOCK_MODE=auto-confirm
